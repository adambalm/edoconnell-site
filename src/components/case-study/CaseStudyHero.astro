---
interface Stat {
  value: string
  label: string
}

interface Props {
  title: string
  subtitle?: string
  date?: string
  byline?: string
  eyebrow?: string
  stats?: Stat[]
}

const {
  title,
  subtitle,
  date,
  byline = "Ed O'Connell",
  eyebrow = 'Case Study · Springfield Commonwealth Academy',
  stats,
} = Astro.props

const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })
  : null
---

<header class="cs-hero">
  <p class="cs-hero__eyebrow">{eyebrow}</p>
  <h1 class="cs-hero__title">{title}</h1>
  {subtitle && (
    <p class="cs-hero__lede">
      <slot name="lede">{subtitle}</slot>
    </p>
  )}

  {stats && stats.length > 0 && (
    <ul class="cs-hero__stats" aria-label="At a glance">
      {stats.map((s) => (
        <li>
          <span class="cs-hero__stat-value">{s.value}</span>
          <span class="cs-hero__stat-label">{s.label}</span>
        </li>
      ))}
    </ul>
  )}

  <p class="cs-hero__byline">
    <span>{byline}</span>
    {formattedDate && (
      <>
        <span class="cs-hero__sep" aria-hidden="true">·</span>
        <time datetime={date}>{formattedDate}</time>
      </>
    )}
  </p>
</header>

<style>
  .cs-hero {
    position: relative;
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
    margin-bottom: var(--space-16);
    border-bottom: 1px solid var(--color-border);
  }

  .cs-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4rem;
    height: 2px;
    background: var(--color-kind-case-study);
  }

  .cs-hero__eyebrow {
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-kind-case-study);
    margin: 0 0 var(--space-8);
  }

  .cs-hero__title {
    font-family: var(--font-prose);
    font-weight: 600;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-8);
    max-width: 20ch;
    color: var(--color-text);
  }

  .cs-hero__lede {
    font-family: var(--font-prose);
    font-size: clamp(1.25rem, 1.5vw, 1.4rem);
    line-height: 1.5;
    color: var(--color-text);
    max-width: 56ch;
    margin: 0 0 var(--space-8);
  }

  .cs-hero__lede :global(em) {
    font-style: italic;
    color: var(--color-kind-case-study);
  }

  .cs-hero__stats {
    list-style: none;
    margin: 0 0 var(--space-8);
    padding: var(--space-5) 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 700px) {
    .cs-hero__stats {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
    }
  }

  .cs-hero__stats li {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    max-width: none;
  }

  .cs-hero__stat-value {
    font-family: var(--font-mono);
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
  }

  .cs-hero__stat-label {
    font-family: var(--font-ui);
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
  }

  .cs-hero__byline {
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .cs-hero__sep {
    margin: 0 var(--space-2);
  }
</style>
