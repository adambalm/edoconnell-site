---
/**
 * /articles/[slug] — SSR route for long-form articles.
 *
 * Fetches an article from Sanity by slug on each request so content
 * changes appear immediately after publish. No rebuild required.
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleMeta from '../../components/ArticleMeta.astro'
import RelatedReading from '../../components/RelatedReading.astro'
import ReadingProgress from '../../components/ReadingProgress.astro'
import SidebarTOC from '../../components/SidebarTOC.astro'
import BackToTop from '../../components/BackToTop.astro'
import { loadQuery } from '../../sanity/lib/load-query'
import { PortableText } from 'astro-portabletext'
import { stegaClean } from '@sanity/client/stega'
import CodeBlock from '../../components/Code.astro'
import Heading2 from '../../components/Heading2.astro'

const ptComponents = {
  type: { code: CodeBlock },
  block: { h2: Heading2 },
}

interface Article {
  _id: string
  title: string
  slug: { current: string }
  kind?: string
  subtitle?: string
  abstract?: string
  body?: any[]
  appendix?: any[]
  epistemicStatus?: string
  publicationReadiness?: string
  audienceContext?: string
  provenance?: {
    author?: string
    generatedBy?: string
    reviewedBy?: string
    context?: string
    date?: string
    confidenceScore?: number
  }
  seo?: {
    metaTitle?: string
    metaDescription?: string
    ogImage?: { asset?: { url?: string } }
  }
}

const { slug } = Astro.params

if (!slug) {
  return Astro.redirect('/articles/')
}

const { data: article } = await loadQuery<Article>({
  query: `*[_type == "article" && slug.current == $slug][0] {
    _id,
    title,
    slug,
    kind,
    subtitle,
    abstract,
    body,
    appendix,
    epistemicStatus,
    publicationReadiness,
    audienceContext,
    provenance,
    seo { metaTitle, metaDescription, ogImage { asset->{ url } } }
  }`,
  params: { slug },
})

if (!article) {
  return Astro.redirect('/articles/')
}

const pageTitle = article.seo?.metaTitle || article.title
const pageDesc = article.seo?.metaDescription || article.abstract
const pageOgImage = article.seo?.ogImage?.asset?.url

// Extract headings BEFORE PortableText renders — astro-portabletext mutates
// block children in place (span → @text), which breaks post-render extraction.
function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
}

const articleHeadings = (article.body || [])
  .filter((block: any) => block._type === 'block' && block.style === 'h2')
  .map((block: any) => {
    const text = stegaClean(
      (block.children || [])
        .filter((child: any) => child._type === 'span')
        .map((child: any) => child.text || '')
        .join('')
    )
    return { text, id: slugify(text) }
  })
  .filter((h: { text: string }) => h.text.length > 0)

const isEssay = stegaClean(article.kind) === 'essay'

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://edoconnell.org').href
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: stegaClean(article.title),
  description: stegaClean(pageDesc || ''),
  url: canonicalUrl,
  mainEntityOfPage: canonicalUrl,
  ...(article.provenance?.date && { datePublished: stegaClean(article.provenance.date) }),
  author: {
    '@type': 'Person',
    name: stegaClean(article.provenance?.author || "Ed O'Connell"),
    url: 'https://edoconnell.org',
  },
  publisher: {
    '@type': 'Person',
    name: "Ed O'Connell",
    url: 'https://edoconnell.org',
  },
  ...(pageOgImage && { image: pageOgImage }),
}
---

<BaseLayout title={pageTitle} description={pageDesc} ogImage={pageOgImage}>
  <script is:inline>
    if (sessionStorage.getItem('transition-in')) {
      document.documentElement.dataset.transitionIn = '';
    }
  </script>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <ReadingProgress />
  <article class:list={['article-page', { essay: isEssay }]}>
    <div class="article-content">
      <header class="article-header">
        <h1>{article.title}</h1>
        {article.subtitle && <p class="article-subtitle">{article.subtitle}</p>}
      </header>

      {!isEssay && <ArticleMeta article={article} />}

      {article.body && (
        <section class="article-body">
          <PortableText value={article.body} components={ptComponents} />
        </section>
      )}

      {article.appendix && article.appendix.length > 0 && (
        <aside class="article-appendix" aria-label="Appendix">
          <h2>Appendix</h2>
          <PortableText value={article.appendix} components={ptComponents} />
        </aside>
      )}

      <RelatedReading currentSlug={stegaClean(article.slug.current)} />
    </div>

    {!isEssay && articleHeadings.length > 0 && <SidebarTOC headings={articleHeadings} />}
  </article>
  <BackToTop />

  <!-- SVG filter for entrance transition (zero dimensions, invisible) -->
  <svg aria-hidden="true" class="svg-defs">
    <defs>
      <filter id="resolve">
        <feTurbulence id="resolve-turb" type="fractalNoise" baseFrequency="0.034" numOctaves="3" seed="2" result="noise" />
        <feDisplacementMap id="resolve-displace" in="SourceGraphic" in2="noise" scale="220" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>
</BaseLayout>

<style>
  .article-page {
    max-width: var(--measure, 65ch);
    margin: 0 auto;
  }

  @media (min-width: 1100px) {
    .article-page {
      display: grid;
      grid-template-columns: minmax(0, var(--measure, 65ch)) 220px;
      gap: 0 var(--space-12);
      max-width: calc(65ch + 220px + var(--space-12));
    }
  }

  .article-content {
    min-width: 0;
  }

  .article-header {
    margin-bottom: var(--space-6, 1.5rem);
  }

  .article-header h1 {
    margin-bottom: var(--space-3, 0.75rem);
  }

  .article-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Body prose */
  .article-body {
    line-height: var(--leading-loose, 1.8);
  }

  .article-body :global(h2) {
    scroll-margin-top: 100px;
    margin-top: var(--space-16, 4rem);
    margin-bottom: var(--space-4, 1rem);
  }

  .article-body :global(h3) {
    margin-top: var(--space-8, 2rem);
    margin-bottom: var(--space-3, 0.75rem);
  }

  .article-body :global(p) {
    margin-bottom: var(--space-4, 1rem);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: var(--space-4, 1rem);
    padding-left: var(--space-6, 1.5rem);
  }

  .article-body :global(li) {
    margin-bottom: var(--space-2, 0.5rem);
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--color-border);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Code blocks — slightly wider than prose for readability */
  .article-body :global(.code-block),
  .article-appendix :global(.code-block) {
    max-width: 72ch;
  }

  /* Appendix */
  .article-appendix {
    margin-top: var(--space-16, 4rem);
    padding-top: var(--space-8, 2rem);
    border-top: 1px solid var(--color-border);
    line-height: var(--leading-loose, 1.8);
  }

  .article-appendix h2 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-6);
  }

  .article-appendix :global(h3) {
    margin-top: var(--space-8, 2rem);
    margin-bottom: var(--space-3, 0.75rem);
    font-size: var(--font-size-md);
  }

  .article-appendix :global(p) {
    margin-bottom: var(--space-4, 1rem);
  }

  .article-appendix :global(ul),
  .article-appendix :global(ol) {
    margin-bottom: var(--space-4, 1rem);
    padding-left: var(--space-6, 1.5rem);
  }

  .article-appendix :global(li) {
    margin-bottom: var(--space-2, 0.5rem);
  }

  /* Essay layout — single column, literary treatment */
  .essay {
    display: block;
    max-width: var(--measure, 65ch);
  }

  .essay .article-header {
    text-align: center;
    margin-bottom: var(--space-12, 3rem);
  }

  .essay .article-subtitle {
    font-style: italic;
    text-align: center;
  }

  .essay .article-body :global(h2) {
    text-align: center;
    margin-top: var(--space-24, 6rem);
    font-weight: 400;
    font-size: var(--font-size-xl);
    letter-spacing: 0.05em;
  }

  .essay .article-body :global(p:first-of-type::first-letter) {
    float: left;
    font-size: 3.5em;
    line-height: 0.8;
    padding-right: 0.08em;
    font-weight: 400;
  }

  .essay .article-body :global(p) {
    margin-bottom: var(--space-5, 1.25rem);
  }

  /* Entrance transition — prevent FOUC */
  :global([data-transition-in]) .article-page {
    opacity: 0;
  }

  .svg-defs {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }
</style>

<script>
  const hasTransition = sessionStorage.getItem('transition-in')

  if (hasTransition) {
    sessionStorage.removeItem('transition-in')

    const article = document.querySelector<HTMLElement>('.article-page')
    const turb = document.getElementById('resolve-turb')
    const displace = document.getElementById('resolve-displace')
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (article && turb && displace && !prefersReduced) {
      const glyphs = '!<>-_\\/[]{}—=+*^?#\u00b7\u2022\u00d7\u00f7'

      // Collect text nodes
      const textNodes: { node: Text; original: string }[] = []
      const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT)
      while (walker.nextNode()) {
        const node = walker.currentNode as Text
        if (node.textContent && node.textContent.trim().length > 0) {
          textNodes.push({ node, original: node.textContent })
        }
      }

      // Scramble all text before first visible frame
      for (const { node, original } of textNodes) {
        let scrambled = ''
        for (let i = 0; i < original.length; i++) {
          const ch = original[i]
          if (ch === ' ' || ch === '\n' || ch === '\r' || ch === '\t') {
            scrambled += ch
          } else {
            scrambled += glyphs[Math.floor(Math.random() * glyphs.length)]
          }
        }
        node.textContent = scrambled
      }

      // Apply filter and reveal (scrambled + high turbulence)
      article.style.filter = 'url(#resolve)'
      article.style.opacity = '1'

      // Animate: turbulence decreases + text resolves
      const totalDuration = 1000
      const start = performance.now()

      function resolveTick(now: number) {
        const elapsed = now - start
        const t = Math.min(elapsed / totalDuration, 1)

        // Turbulence: fast decrease over first 500ms (ease-out quad)
        const turbT = Math.min(elapsed / 500, 1)
        const turbEased = 1 - (1 - turbT) * (1 - turbT)
        displace!.setAttribute('scale', String(220 * (1 - turbEased)))
        turb!.setAttribute('baseFrequency', String(0.034 - turbEased * 0.022))

        // Text: resolves from 200ms to 1000ms
        const textT = Math.max(0, Math.min((elapsed - 200) / 800, 1))
        for (const { node, original } of textNodes) {
          let result = ''
          for (let i = 0; i < original.length; i++) {
            const ch = original[i]
            if (ch === ' ' || ch === '\n' || ch === '\r' || ch === '\t') {
              result += ch
              continue
            }
            if (Math.random() < textT) {
              result += ch
            } else {
              result += glyphs[Math.floor(Math.random() * glyphs.length)]
            }
          }
          node.textContent = result
        }

        if (t < 1) {
          requestAnimationFrame(resolveTick)
        } else {
          // Restore exact originals and clean up
          for (const { node, original } of textNodes) {
            node.textContent = original
          }
          article!.style.filter = ''
          article!.style.opacity = ''
          document.documentElement.removeAttribute('data-transition-in')
          displace!.setAttribute('scale', '0')
          turb!.setAttribute('baseFrequency', '0.012')
        }
      }

      requestAnimationFrame(resolveTick)
    } else {
      // Reduced motion or missing elements — show immediately
      document.documentElement.removeAttribute('data-transition-in')
    }
  }
</script>
