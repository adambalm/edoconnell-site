---
/**
 * /experiments/handwritten/[slug]/[page]
 *
 * Renders one transcribed Supernote page from the `handwritten` content
 * collection. Prerendered at build time so visits cost zero function
 * invocations and zero Sanity API calls — content updates ship via redeploy.
 */
export const prerender = true

import { getCollection, type CollectionEntry } from 'astro:content'
import HandwrittenPageLayout from '../../../../layouts/HandwrittenPageLayout.astro'

export async function getStaticPaths() {
  const entries = await getCollection('handwritten')
  return entries.map((entry) => {
    const parts = entry.id.split('/')
    const slug = parts[0]
    // Astro 5 legacy `type: 'content'` includes the file extension in entry.id
    // (e.g. "go-on-now/p1.md"). Strip it so the URL stays /<slug>/<page>.
    const page = parts.slice(1).join('/').replace(/\.mdx?$/, '')
    return {
      params: { slug, page },
      props: { entry },
    }
  })
}

interface Props {
  entry: CollectionEntry<'handwritten'>
}

const { entry } = Astro.props
const { Content } = await entry.render()
---

<HandwrittenPageLayout frontmatter={entry.data}>
  <Content />
</HandwrittenPageLayout>
